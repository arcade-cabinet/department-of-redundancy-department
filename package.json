{
	"name": "department-of-redundancy-department",
	"version": "1.0.0",
	"private": true,
	"description": "Mobile-first arcade rail shooter set in a haunted corporate office. Babylon.js + Capacitor.",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite",
		"start": "vite",
		"build": "tsc -p tsconfig.json --noEmit && vite build",
		"build:native": "tsc -p tsconfig.json --noEmit && cross-env CAPACITOR=true vite build",
		"preview": "vite preview --port 5173",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run --passWithNoTests",
		"test:node": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:all": "pnpm test:node && pnpm test:e2e",
		"assets:check": "node scripts/check-asset-manifest.mjs",
		"cap:sync": "pnpm build:native && cap sync"
	},
	"dependencies": {
		"@babylonjs/core": "^8.46.0",
		"@babylonjs/gui": "^8.46.0",
		"@babylonjs/loaders": "^8.46.0",
		"@capacitor/android": "^8.3.1",
		"@capacitor/cli": "^8.3.1",
		"@capacitor/core": "^8.3.1",
		"@capacitor/ios": "^8.3.1",
		"@capacitor/preferences": "^8.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@playwright/test": "^1.59.1",
		"@size-limit/file": "^12.1.0",
		"@types/node": "^25.6.0",
		"cross-env": "^10.1.0",
		"size-limit": "^12.1.0",
		"typescript": "~6.0.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"size-limit": [
		{
			"path": "dist/assets/*.js",
			"limit": "1000 KB"
		}
	],
	"pnpm": {
		"overrides": {
			"vitest": "$vitest"
		}
	}
}
