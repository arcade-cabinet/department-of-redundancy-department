# Hoist transitive deps that @capacitor/assets@3.0.5 fails to declare
# (kleur, debug, tslib). The package's dist/ files require them but
# they're missing from its package.json — pnpm's strict node_modules
# layout breaks the require resolution. Hoisting puts them at the
# top level where the broken requires can find them.
public-hoist-pattern[]=*kleur*
public-hoist-pattern[]=*debug*
public-hoist-pattern[]=*tslib*
shamefully-hoist=true

auto-install-peers=true
